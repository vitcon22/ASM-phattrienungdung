@model FruitShop.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
    // Serialize dữ liệu chart dùng JSON
    var topLabels = string.Join(",", Model.TopFruits.Select(x => $"'{x.FruitName}'"));
    var topData   = string.Join(",", Model.TopFruits.Select(x => x.TotalQuantity));
    var dayLabels = string.Join(",", Model.Last7DaysRevenue.Select(x => $"'{x.DayLabel}'"));
    var dayData   = string.Join(",", Model.Last7DaysRevenue.Select(x => x.Revenue));
}
@section Breadcrumb {
    <li class="breadcrumb-item active">Dashboard</li>
}

<!-- Stats Cards Row -->
<div class="row g-3 mb-4">
    <!-- Doanh thu hôm nay -->
    <div class="col-md-6 col-lg-3">
        <div class="stat-card stat-card-green">
            <div class="stat-icon"><i class="fas fa-dollar-sign"></i></div>
            <div class="stat-info">
                <div class="stat-label">Doanh thu hôm nay</div>
                <div class="stat-value">@Model.RevenueToday.ToString("N0")đ</div>
            </div>
        </div>
    </div>
    <!-- Doanh thu tháng -->
    <div class="col-md-6 col-lg-3">
        <div class="stat-card stat-card-blue">
            <div class="stat-icon"><i class="fas fa-chart-bar"></i></div>
            <div class="stat-info">
                <div class="stat-label">Doanh thu tháng này</div>
                <div class="stat-value">@Model.RevenueThisMonth.ToString("N0")đ</div>
            </div>
        </div>
    </div>
    <!-- Doanh thu năm -->
    <div class="col-md-6 col-lg-3">
        <div class="stat-card stat-card-orange">
            <div class="stat-icon"><i class="fas fa-chart-line"></i></div>
            <div class="stat-info">
                <div class="stat-label">Doanh thu năm nay</div>
                <div class="stat-value">@Model.RevenueThisYear.ToString("N0")đ</div>
            </div>
        </div>
    </div>
    <!-- Tổng đơn hàng -->
    <div class="col-md-6 col-lg-3">
        <div class="stat-card stat-card-purple">
            <div class="stat-icon"><i class="fas fa-shopping-bag"></i></div>
            <div class="stat-info">
                <div class="stat-label">Tổng đơn hàng</div>
                <div class="stat-value">@Model.TotalOrders</div>
            </div>
        </div>
    </div>
</div>

<!-- Secondary stats -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="mini-stat-card">
            <i class="fas fa-users text-success me-2"></i>
            <span>Khách hàng: <strong>@Model.TotalCustomers</strong></span>
        </div>
    </div>
    <div class="col-md-4">
        <div class="mini-stat-card">
            <i class="fas fa-lemon text-warning me-2"></i>
            <span>Sản phẩm: <strong>@Model.TotalFruits</strong></span>
        </div>
    </div>
    <div class="col-md-4">
        <div class="mini-stat-card">
            <i class="fas fa-clock text-info me-2"></i>
            <span>Chờ xác nhận: <strong class="text-warning">@Model.PendingOrders</strong></span>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-4 mb-4">
    <!-- Doanh thu 7 ngày - Line Chart -->
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="mb-0"><i class="fas fa-chart-line me-2 text-success"></i>Doanh thu 7 ngày gần nhất</h6>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" height="200"></canvas>
            </div>
        </div>
    </div>
    <!-- Đơn hàng theo trạng thái - Doughnut -->
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="mb-0"><i class="fas fa-chart-pie me-2 text-primary"></i>Đơn hàng theo trạng thái</h6>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="statusChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Top Fruits + Low Stock -->
<div class="row g-4">
    <!-- Top 5 trái cây bán chạy - Bar Chart -->
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0"><i class="fas fa-trophy me-2 text-warning"></i>Top 5 trái cây bán chạy</h6>
            </div>
            <div class="card-body">
                <canvas id="topFruitsChart" height="200"></canvas>
            </div>
        </div>
    </div>
    <!-- Tồn kho thấp -->
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header d-flex justify-content-between">
                <h6 class="mb-0"><i class="fas fa-exclamation-triangle me-2 text-danger"></i>Tồn kho thấp</h6>
                <span class="badge bg-danger">@Model.LowStockFruits.Count sản phẩm</span>
            </div>
            <div class="card-body p-0">
                @if (!Model.LowStockFruits.Any())
                {
                    <p class="text-center text-muted py-3">Không có sản phẩm nào sắp hết!</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center">Tồn kho</th>
                                <th class="text-center">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in Model.LowStockFruits)
                            {
                                <tr>
                                    <td class="small">@f.FruitName</td>
                                    <td class="text-center">
                                        <span class="badge bg-danger">@f.StockQuantity @f.Unit</span>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Fruit" asp-action="Edit" asp-route-id="@f.FruitId"
                                           class="btn btn-xs btn-outline-warning" style="font-size:0.7rem;padding:2px 6px;">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// === LINE CHART: Doanh thu 7 ngày ===
const ctx1 = document.getElementById('revenueChart').getContext('2d');
new Chart(ctx1, {
    type: 'line',
    data: {
        labels: [@Html.Raw(dayLabels)],
        datasets: [{
            label: 'Doanh thu (đ)',
            data: [@Html.Raw(dayData)],
            borderColor: '#2E7D32',
            backgroundColor: 'rgba(46,125,50,0.1)',
            borderWidth: 2,
            fill: true,
            tension: 0.4,
            pointBackgroundColor: '#2E7D32'
        }]
    },
    options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
            y: { ticks: { callback: v => v.toLocaleString('vi') + 'đ' } }
        }
    }
});

// === DOUGHNUT CHART: Trạng thái đơn hàng ===
const ctx2 = document.getElementById('statusChart').getContext('2d');
new Chart(ctx2, {
    type: 'doughnut',
    data: {
        labels: ['Chờ xác nhận','Đã xác nhận','Đang giao','Đã giao','Đã huỷ'],
        datasets: [{
            data: [@Model.PendingOrders, @Model.ConfirmedOrders, @Model.ShippingOrders, @Model.DeliveredOrders, @Model.CancelledOrders],
            backgroundColor: ['#FFC107','#2196F3','#00BCD4','#4CAF50','#F44336'],
            hoverOffset: 8
        }]
    },
    options: {
        responsive: true,
        plugins: {
            legend: { position: 'bottom', labels: { padding: 10, font: { size: 11 } } }
        }
    }
});

// === BAR CHART: Top 5 trái cây bán chạy ===
const ctx3 = document.getElementById('topFruitsChart').getContext('2d');
new Chart(ctx3, {
    type: 'bar',
    data: {
        labels: [@Html.Raw(topLabels)],
        datasets: [{
            label: 'Số lượng bán',
            data: [@Html.Raw(topData)],
            backgroundColor: ['#2E7D32','#388E3C','#43A047','#4CAF50','#66BB6A'],
            borderRadius: 6
        }]
    },
    options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true } }
    }
});
</script>
}
