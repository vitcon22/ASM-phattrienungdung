@model List<FruitShop.Models.Entities.Wishlist>
@{
    ViewData["Title"] = "Danh sách yêu thích";
    Layout = "_LayoutUser";
}
@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Account" asp-action="Profile">Tài khoản</a></li>
    <li class="breadcrumb-item active">Yêu thích</li>
}

<div class="container py-4">
    <div class="page-header animate-fade-in-up mb-4">
        <h1 class="page-header-title">
            <i class="fas fa-heart me-2" style="color:var(--primary);"></i>Danh sách yêu thích
        </h1>
        <p class="page-header-subtitle mb-0">@Model.Count sản phẩm đã lưu</p>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 animate-fade-in-up">
            <i class="fas fa-heart-broken fa-4x text-muted mb-3"></i>
            <h5 class="text-muted">Bạn chưa có sản phẩm yêu thích nào</h5>
            <p class="text-muted">Nhấn vào biểu tượng trái tim để lưu sản phẩm yêu thích</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">
                <i class="fas fa-shopping-bag me-1"></i>Khám phá sản phẩm
            </a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 animate-fade-in-up">
                    <div class="card h-100 shadow-sm wishlist-card">
                        <div class="card-body p-3">
                            <div class="d-flex gap-3">
                                <img src="~/images/fruits/@(item.ImageUrl ?? "default.jpg")"
                                     style="width:80px;height:80px;object-fit:cover;border-radius:10px;"
                                     onerror="this.src='/images/fruits/default.jpg'" />
                                <div class="flex-grow-1">
                                    <h6 class="mb-1 fw-bold">@item.FruitName</h6>
                                    <div class="text-primary fw-bold mb-2">@item.Price.ToString("N0")đ</div>
                                    @if (item.InStock)
                                    {
                                        <span class="badge bg-success mb-2">Còn hàng</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger mb-2">Hết hàng</span>
                                    }
                                    <div class="d-flex gap-2">
                                        <a asp-controller="Fruit" asp-action="Details" asp-route-id="@item.FruitId"
                                           class="btn btn-outline-primary btn-sm flex-fill">
                                            <i class="fas fa-eye me-1"></i>Chi tiết
                                        </a>
                                        @if (item.InStock)
                                        {
                                            <form asp-controller="Order" asp-action="AddToCart" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="fruitId" value="@item.FruitId" />
                                                <input type="hidden" name="quantity" value="1" />
                                                <button type="submit" class="btn btn-success btn-sm" title="Thêm vào giỏ">
                                                    <i class="fas fa-cart-plus"></i>
                                                </button>
                                            </form>
                                        }
                                        <form asp-controller="Wishlist" asp-action="Toggle" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="fruitId" value="@item.FruitId" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm" title="Xóa khỏi yêu thích">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-2 small text-muted">
                                <i class="fas fa-clock me-1"></i>Đã lưu: @item.AddedAt.ToString("dd/MM/yyyy")
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .wishlist-card { transition: transform 0.2s; }
    .wishlist-card:hover { transform: translateY(-2px); }
</style>
