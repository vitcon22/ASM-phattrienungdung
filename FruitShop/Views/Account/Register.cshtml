@model FruitShop.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - FruitShop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body.auth-body { overflow: auto; }
        .auth-brand-float {
            position: fixed; top: 1.5rem; left: 1.5rem;
            display: flex; align-items: center; gap: 0.6rem;
            color: #fff; font-weight: 800; font-size: 1.1rem; z-index: 10;
        }
        .auth-brand-float .brand-icon {
            width: 34px; height: 34px;
            background: linear-gradient(135deg, #10B981, #06B6D4);
            border-radius: 9px; display: flex; align-items: center; justify-content: center;
        }
        .input-icon-wrap { position: relative; }
        .input-icon-wrap .input-group-text {
            position: absolute; left: 0; top: 0; bottom: 0;
            background: none; border: none;
            padding-left: 0.85rem; padding-right: 0;
            color: var(--text-muted); z-index: 5;
        }
        .input-icon-wrap .form-control { padding-left: 2.5rem; }
        .input-icon-wrap.has-error .form-control { border-color: #EF4444; }
        .back-link {
            position: fixed; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
            color: rgba(255,255,255,0.4); font-size: 0.82rem; text-decoration: none;
            display: flex; align-items: center; gap: 0.4rem;
            transition: var(--transition);
        }
        .back-link:hover { color: rgba(255,255,255,0.8); }
        .register-benefits {
            display: flex; flex-direction: column; gap: 0.6rem;
            margin-bottom: 1.5rem;
        }
        .register-benefit {
            display: flex; align-items: center; gap: 0.6rem;
            font-size: 0.85rem; color: var(--text-secondary);
        }
        .register-benefit i {
            width: 28px; height: 28px;
            background: var(--primary-pale);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            color: var(--primary);
            font-size: 0.8rem;
            flex-shrink: 0;
        }
    </style>
</head>
<body class="auth-body">

<!-- Brand -->
<div class="auth-brand-float">
    <div class="brand-icon"><i class="fas fa-apple-alt" style="color:#fff;"></i></div>
    <span>FruitShop</span>
</div>

<div class="auth-container" style="max-width:520px;">
    <div class="auth-card">

        <!-- Logo -->
        <div class="auth-logo">
            <div class="auth-logo-icon">
                <i class="fas fa-apple-alt"></i>
            </div>
            <h1>FruitShop</h1>
            <p>Tạo tài khoản mới</p>
        </div>

        <h4 class="auth-title">Đăng ký tài khoản</h4>

        <!-- Benefits -->
        <div class="register-benefits">
            <div class="register-benefit">
                <i class="fas fa-check"></i>
                <span>Mua sắm trái cây với giá ưu đãi</span>
            </div>
            <div class="register-benefit">
                <i class="fas fa-check"></i>
                <span>Theo dõi đơn hàng dễ dàng</span>
            </div>
            <div class="register-benefit">
                <i class="fas fa-check"></i>
                <span>Nhận ưu đãi và khuyến mãi đặc biệt</span>
            </div>
        </div>

        <form asp-action="Register" method="post" id="registerForm">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block");border-radius:10px;border:none;font-size:0.85rem;"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label" style="font-weight:600;color:var(--text-secondary);font-size:0.82rem;"></label>
                    <div class="input-icon-wrap">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-user"></i></span>
                            <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" style="border-radius:10px;" />
                        </div>
                    </div>
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label" style="font-weight:600;color:var(--text-secondary);font-size:0.82rem;"></label>
                    <div class="input-icon-wrap">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="email@example.com" style="border-radius:10px;" />
                        </div>
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mt-2">
                <div class="col-md-6">
                    <label asp-for="Password" class="form-label" style="font-weight:600;color:var(--text-secondary);font-size:0.82rem;"></label>
                    <div class="input-icon-wrap">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            <input asp-for="Password" class="form-control" placeholder="Tối thiểu 6 ký tự" style="border-radius:10px;" />
                        </div>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label" style="font-weight:600;color:var(--text-secondary);font-size:0.82rem;"></label>
                    <div class="input-icon-wrap">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" style="border-radius:10px;" />
                        </div>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mt-2">
                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label" style="font-weight:600;color:var(--text-secondary);font-size:0.82rem;"></label>
                    <div class="input-icon-wrap">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-phone"></i></span>
                            <input asp-for="Phone" class="form-control" placeholder="0901 234 567" style="border-radius:10px;" />
                        </div>
                    </div>
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Address" class="form-label" style="font-weight:600;color:var(--text-secondary);font-size:0.82rem;"></label>
                    <div class="input-icon-wrap">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-map-marker-alt"></i></span>
                            <input asp-for="Address" class="form-control" placeholder="Địa chỉ của bạn" style="border-radius:10px;" />
                        </div>
                    </div>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-auth w-100 mt-3" id="btnRegister">
                <i class="fas fa-user-plus me-2"></i>Tạo tài khoản
            </button>

            <p class="text-center mt-3 mb-0" style="font-size:0.82rem;color:var(--text-muted);">
                Bằng việc đăng ký, bạn đồng ý với
                <a href="#" style="color:var(--primary);font-weight:600;">Điều khoản sử dụng</a>
                &
                <a href="#" style="color:var(--primary);font-weight:600;">Chính sách bảo mật</a>
            </p>
        </form>

        <div class="auth-footer">
            <p>Đã có tài khoản? <a asp-controller="Account" asp-action="Login">Đăng nhập ngay</a></p>
        </div>
    </div>
</div>

<a class="back-link" asp-controller="Home" asp-action="Index">
    <i class="fas fa-arrow-left"></i> Quay lại cửa hàng
</a>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<partial name="_ValidationScripts" />
<script>
    document.getElementById('registerForm').addEventListener('submit', function () {
        const btn = document.getElementById('btnRegister');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Đang xử lý...';
    });
</script>
</body>
</html>
