@model FruitShop.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "_LayoutUser";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <i class="fas fa-key fa-3x text-success mb-3"></i>
                        <h4 class="fw-bold">Quên mật khẩu?</h4>
                        <p class="text-muted">Nhập email của bạn và chúng tôi sẽ gửi link đặt lại mật khẩu.</p>
                    </div>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }

                    <form asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-semibold">Địa chỉ Email</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-envelope text-muted"></i></span>
                                <input asp-for="Email" class="form-control" placeholder="example@email.com" required />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100 py-2 mb-3">
                            <i class="fas fa-paper-plane me-2"></i>Gửi yêu cầu
                        </button>

                        <div class="text-center">
                            <a asp-action="Login" class="text-decoration-none small text-success">
                                <i class="fas fa-arrow-left me-1"></i>Quay lại đăng nhập
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
