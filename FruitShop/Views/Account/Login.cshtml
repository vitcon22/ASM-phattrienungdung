@model FruitShop.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - FruitShop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body.auth-body { overflow: hidden; }
        .auth-brand-float {
            position: fixed; top: 1.5rem; left: 1.5rem;
            display: flex; align-items: center; gap: 0.6rem;
            color: #fff; font-weight: 800; font-size: 1.1rem;
            z-index: 10;
        }
        .auth-brand-float .brand-icon {
            width: 34px; height: 34px;
            background: linear-gradient(135deg, #10B981, #06B6D4);
            border-radius: 9px; display: flex; align-items: center; justify-content: center;
        }
        .input-icon-wrap {
            position: relative;
        }
        .input-icon-wrap .input-group-text {
            position: absolute; left: 0; top: 0; bottom: 0;
            background: none; border: none;
            padding-left: 0.85rem; padding-right: 0;
            color: var(--text-muted);
            z-index: 5;
        }
        .input-icon-wrap .form-control { padding-left: 2.5rem; }
        .password-toggle {
            position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%);
            background: none; border: none; color: var(--text-muted); cursor: pointer;
            z-index: 5; padding: 0.25rem;
        }
        .password-toggle:hover { color: var(--text-secondary); }
        .back-link {
            position: fixed; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
            color: rgba(255,255,255,0.4); font-size: 0.82rem; text-decoration: none;
            display: flex; align-items: center; gap: 0.4rem;
            transition: var(--transition);
        }
        .back-link:hover { color: rgba(255,255,255,0.8); }
        .auth-features {
            position: fixed; bottom: 3.5rem; left: 50%; transform: translateX(-50%);
            display: flex; gap: 1.5rem; align-items: center;
        }
        .auth-feature-item {
            display: flex; align-items: center; gap: 0.4rem;
            color: rgba(255,255,255,0.4); font-size: 0.75rem;
        }
        .auth-feature-item i { color: var(--primary-light); font-size: 0.8rem; }
        .forgot-link {
            color: var(--text-secondary); font-size: 0.82rem; font-weight: 500;
            text-decoration: none; transition: var(--transition);
        }
        .forgot-link:hover { color: var(--primary); }
    </style>
</head>
<body class="auth-body">

<!-- Brand -->
<div class="auth-brand-float">
    <div class="brand-icon"><i class="fas fa-apple-alt" style="color:#fff;"></i></div>
    <span>FruitShop</span>
</div>

<div class="auth-container">
    <div class="auth-card">

        <!-- Logo -->
        <div class="auth-logo">
            <div class="auth-logo-icon">
                <i class="fas fa-apple-alt"></i>
            </div>
            <h1>FruitShop</h1>
            <p>Chào mừng bạn quay trở lại!</p>
        </div>

        <h4 class="auth-title">Đăng nhập vào tài khoản</h4>

        <form asp-action="Login" method="post" id="loginForm">
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" style="border-radius:10px;border:none;background:#FEE2E2;color:#991B1B;padding:0.75rem 1rem;font-size:0.85rem;">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                </div>
            }

            <!-- Email -->
            <div class="mb-3">
                <label asp-for="Email" class="form-label" style="font-weight:600;color:var(--text-secondary);font-size:0.82rem;">Email</label>
                <div class="input-icon-wrap">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="email@fruitshop.vn" style="border-radius:10px;" />
                    </div>
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <!-- Password -->
            <div class="mb-3">
                <label asp-for="Password" class="form-label" style="font-weight:600;color:var(--text-secondary);font-size:0.82rem;">Mật khẩu</label>
                <div class="input-icon-wrap">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                        <input asp-for="Password" class="form-control" placeholder="Nhập mật khẩu" id="passwordInput" style="border-radius:10px;padding-right:2.5rem;" />
                        <button class="password-toggle" type="button" onclick="togglePassword()">
                            <i class="fas fa-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" style="width:16px;height:16px;" />
                    <label asp-for="RememberMe" class="form-check-label" style="font-size:0.82rem;font-weight:500;color:var(--text-secondary);">Ghi nhớ</label>
                </div>
                <a asp-action="ForgotPassword" class="forgot-link">Quên mật khẩu?</a>
            </div>

            <button type="submit" class="btn btn-auth w-100" id="btnLogin">
                <span class="btn-text"><i class="fas fa-sign-in-alt me-2"></i>Đăng nhập</span>
                <span class="btn-spinner d-none"><i class="fas fa-spinner fa-spin me-2"></i>Đang xử lý...</span>
            </button>
        </form>

        <div class="social-login-divider">
            <span>Hoặc đăng nhập với</span>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="ExternalLogin" asp-route-provider="Google" asp-route-returnUrl="@ViewBag.ReturnUrl"
               class="btn social-btn flex-fill">
                <svg viewBox="0 0 24 24" width="18" height="18" style="margin-right:6px;"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                Google
            </a>
            <a asp-action="ExternalLogin" asp-route-provider="Facebook" asp-route-returnUrl="@ViewBag.ReturnUrl"
               class="btn social-btn flex-fill">
                <i class="fab fa-facebook" style="color:#1877F2;margin-right:6px;font-size:1rem;"></i>
                Facebook
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success mt-3" style="border-radius:10px;">
                <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            </div>
        }

        <div class="auth-footer">
            <p>Chưa có tài khoản? <a asp-controller="Account" asp-action="Register">Đăng ký ngay</a></p>
        </div>
    </div>
</div>

<!-- Bottom -->
<div class="auth-features">
    <div class="auth-feature-item"><i class="fas fa-shield-alt"></i> Bảo mật</div>
    <div class="auth-feature-item"><i class="fas fa-bolt"></i> Nhanh chóng</div>
    <div class="auth-feature-item"><i class="fas fa-heart"></i> Miễn phí</div>
</div>
<a class="back-link" asp-controller="Home" asp-action="Index">
    <i class="fas fa-arrow-left"></i> Quay lại cửa hàng
</a>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<partial name="_ValidationScripts" />
<script>
    function togglePassword() {
        const input = document.getElementById('passwordInput');
        const icon  = document.getElementById('eyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.className = 'fas fa-eye-slash';
        } else {
            input.type = 'password';
            icon.className = 'fas fa-eye';
        }
    }
    document.getElementById('loginForm').addEventListener('submit', function () {
        const btn = document.getElementById('btnLogin');
        btn.querySelector('.btn-text').classList.add('d-none');
        btn.querySelector('.btn-spinner').classList.remove('d-none');
        btn.disabled = true;
    });
</script>
</body>
</html>
