@model FruitShop.Models.Entities.User
@{
    ViewData["Title"] = "Thông tin cá nhân";
    Layout = ViewBag.UserLayout?.ToString() ?? "_LayoutUser";
    var role = Context.Session.GetString("UserRole") ?? "Customer";
}
@if (role is "Admin" or "Staff")
{
    @section Breadcrumb {
        <li class="breadcrumb-item active">Hồ sơ</li>
    }
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <!-- Profile Header Card -->
            <div class="card mb-4 profile-header-card">
                <div class="card-body d-flex align-items-center gap-4 p-4">
                    <div class="profile-avatar">
                        <i class="fas fa-user-circle"></i>
                    </div>
                    <div>
                        <h4 class="mb-1 fw-bold">@Model.FullName</h4>
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <span class="badge bg-success">@Model.RoleName</span>
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-light text-success border border-success">
                                    <i class="fas fa-circle me-1" style="font-size:.5rem"></i>Đang hoạt động
                                </span>
                            }
                        </div>
                        <small class="text-muted">
                            <i class="fas fa-envelope me-1"></i>@Model.Email
                        </small>
                    </div>
                </div>
            </div>

            <!-- Tabs -->
            <ul class="nav nav-tabs mb-4" id="profileTabs">
                <li class="nav-item">
                    <a class="nav-link active" data-bs-toggle="tab" href="#editInfo">
                        <i class="fas fa-user-edit me-2"></i>Sửa thông tin
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#changePwd">
                        <i class="fas fa-lock me-2"></i>Đổi mật khẩu
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#orderInfo">
                        <i class="fas fa-history me-2"></i>Đơn hàng
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#wishlistInfo">
                        <i class="fas fa-heart text-danger me-2"></i>Yêu thích
                    </a>
                </li>
            </ul>

            <div class="tab-content">
                <!-- Tab 1: Edit Info -->
                <div class="tab-pane fade show active" id="editInfo">
                    <div class="card">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="fas fa-user-edit me-2 text-success"></i>Cập nhật thông tin cá nhân</h6>
                        </div>
                        <div class="card-body">
                            <form asp-action="Profile" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="UserId" value="@Model.UserId" />
                                <input type="hidden" name="Email" value="@Model.Email" />
                                <input type="hidden" name="Password" value="@Model.Password" />
                                <input type="hidden" name="RoleId" value="@Model.RoleId" />
                                <input type="hidden" name="IsActive" value="@Model.IsActive" />

                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Họ và tên</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-user"></i></span>
                                        <input type="text" name="FullName" value="@Model.FullName" class="form-control" required />
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Email</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                        <input type="email" value="@Model.Email" class="form-control" readonly />
                                    </div>
                                    <small class="text-muted">Email không thể thay đổi</small>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold">Số điện thoại</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="fas fa-phone"></i></span>
                                            <input type="tel" name="Phone" value="@Model.Phone" class="form-control" />
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-semibold">Địa chỉ</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-map-marker-alt"></i></span>
                                        <input type="text" name="Address" value="@Model.Address" class="form-control" />
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-success px-4">
                                    <i class="fas fa-save me-2"></i>Lưu thay đổi
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Tab 2: Change Password -->
                <div class="tab-pane fade" id="changePwd">
                    <div class="card">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="fas fa-lock me-2 text-warning"></i>Đổi mật khẩu</h6>
                        </div>
                        <div class="card-body">
                            <form asp-action="ChangePassword" method="post">
                                @Html.AntiForgeryToken()
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Mật khẩu hiện tại</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                                        <input type="password" name="currentPassword" class="form-control" placeholder="Nhập mật khẩu hiện tại" required />
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Mật khẩu mới</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-key"></i></span>
                                        <input type="password" name="newPassword" class="form-control" placeholder="Tối thiểu 6 ký tự" required />
                                    </div>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-semibold">Xác nhận mật khẩu mới</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-check-circle"></i></span>
                                        <input type="password" name="confirmPassword" class="form-control" placeholder="Nhập lại mật khẩu mới" required />
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-warning px-4">
                                    <i class="fas fa-sync-alt me-2"></i>Đổi mật khẩu
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Tab 3: Orders -->
                <div class="tab-pane fade" id="orderInfo">
                    <div class="card">
                        <div class="card-body text-center py-4">
                            <i class="fas fa-shopping-bag fa-3x text-success mb-3"></i>
                            <p class="text-muted">Xem toàn bộ đơn hàng của bạn tại trang lịch sử đơn hàng.</p>
                            <a asp-controller="Order" asp-action="History" class="btn btn-success">
                                <i class="fas fa-history me-2"></i>Xem lịch sử đơn hàng
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Tab 4: Wishlist -->
                <div class="tab-pane fade" id="wishlistInfo">
                    <div class="card">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="fas fa-heart text-danger me-2"></i>Sản phẩm yêu thích</h6>
                        </div>
                        <div class="card-body p-0">
                            @if (ViewBag.Wishlists == null || ((List<FruitShop.Models.Entities.Wishlist>)ViewBag.Wishlists).Count == 0)
                            {
                                <div class="text-center py-5">
                                    <i class="far fa-heart fa-3x text-muted mb-3 d-block"></i>
                                    <p class="text-muted">Bạn chưa lưu sản phẩm nào.</p>
                                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-success">Khám phá ngay</a>
                                </div>
                            }
                            else
                            {
                                <ul class="list-group list-group-flush">
                                    @foreach (var w in (List<FruitShop.Models.Entities.Wishlist>)ViewBag.Wishlists)
                                    {
                                        <li class="list-group-item d-flex align-items-center justify-content-between p-3" id="wishlist-item-@w.FruitId">
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="~/images/fruits/@(w.ImageUrl ?? "default.jpg")" alt="@w.FruitName" class="rounded object-fit-cover shadow-sm" style="width: 60px; height: 60px;" />
                                                <div>
                                                    <h6 class="mb-1 fw-bold">
                                                        <a asp-controller="Fruit" asp-action="Details" asp-route-id="@w.FruitId" class="text-dark text-decoration-none">@w.FruitName</a>
                                                    </h6>
                                                    <div class="text-success fw-semibold mb-1">@w.Price.ToString("N0")đ / @w.Unit</div>
                                                    <small class="text-muted"><i class="far fa-clock me-1"></i>Thêm ngày @w.AddedAt.ToString("dd/MM/yyyy")</small>
                                                </div>
                                            </div>
                                            <div>
                                                @if (w.InStock)
                                                {
                                                    <form asp-controller="Order" asp-action="AddToCart" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="fruitId" value="@w.FruitId" />
                                                        <input type="hidden" name="quantity" value="1" />
                                                        <button type="submit" class="btn btn-sm btn-success me-2" title="Thêm vào giỏ">
                                                            <i class="fas fa-cart-plus"></i>
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger me-2">Hết hàng</span>
                                                }
                                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeWishlist(@w.FruitId)" title="Xoá khỏi danh sách">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function removeWishlist(fruitId) {
            if(!confirm('Xoá sản phẩm này khỏi mục yêu thích?')) return;
            fetch('/Wishlist/Toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ fruitId: fruitId })
            })
            .then(res => res.json())
            .then(data => {
                if(data.success && !data.isInWishlist) {
                    const item = document.getElementById('wishlist-item-' + fruitId);
                    if(item) {
                        item.style.transition = 'opacity 0.3s';
                        item.style.opacity = '0';
                        setTimeout(() => item.remove(), 300);
                    }
                }
            });
        }
    </script>
}
