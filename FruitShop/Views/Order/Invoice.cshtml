@model FruitShop.Models.Entities.Order
@{
    ViewData["Title"] = $"Hoá đơn #{Model.OrderId}";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Hoá đơn #@Model.OrderId - FruitShop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { font-family: 'Segoe UI', Tahoma, sans-serif; background: #f5f5f5; }
        .invoice-box {
            max-width: 820px;
            margin: 30px auto;
            padding: 40px;
            background: #fff;
            box-shadow: 0 0 10px rgba(0,0,0,.1);
        }
        .invoice-header { border-bottom: 3px solid #198754; padding-bottom: 12px; margin-bottom: 20px; }
        .brand { color: #198754; font-weight: 800; font-size: 1.8rem; }
        .text-end-strong { text-align: right; font-weight: 600; }
        table { width: 100%; border-collapse: collapse; margin-top: 14px; }
        th, td { padding: 8px 10px; border-bottom: 1px solid #eee; }
        th { background: #f8f9fa; text-align: left; }
        .total-row td { font-size: 1.1rem; font-weight: 700; border-top: 2px solid #198754; }
        .muted { color: #777; font-size: .9rem; }
        @@media print {
            body { background: #fff; }
            .invoice-box { box-shadow: none; margin: 0; padding: 20px; }
            .no-print { display: none !important; }
        }
    </style>
</head>
<body>
<div class="invoice-box">
    <div class="d-flex justify-content-between align-items-center no-print mb-3">
        <a href="/Order/Details/@Model.OrderId" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
        <button class="btn btn-success btn-sm" onclick="window.print()">
            <i class="fas fa-print"></i> In hoá đơn
        </button>
    </div>

    <div class="invoice-header d-flex justify-content-between">
        <div>
            <div class="brand">🍎 FruitShop</div>
            <div class="muted">Cửa hàng trái cây tươi sạch</div>
            <div class="muted">Hotline: 0901.111.111</div>
        </div>
        <div class="text-end">
            <h3 class="mb-1">HOÁ ĐƠN</h3>
            <div><strong>Số:</strong> #@Model.OrderId</div>
            <div><strong>Ngày:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-6">
            <div class="muted">Khách hàng:</div>
            <div class="fw-semibold">@Model.CustomerName</div>
            <div class="muted small">@Model.ShippingAddress</div>
        </div>
        <div class="col-6 text-end">
            <div class="muted">Trạng thái:</div>
            <div><span class="badge bg-@Model.GetStatusBadge()">@Model.GetStatusText()</span></div>
            <div class="muted mt-1">Thanh toán: <strong>@Model.GetPaymentMethodText()</strong></div>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th style="width:40px">#</th>
                <th>Sản phẩm</th>
                <th class="text-end" style="width:90px">ĐG</th>
                <th class="text-center" style="width:70px">SL</th>
                <th class="text-end" style="width:120px">Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @{ int i = 1; }
            @foreach (var d in Model.OrderDetails)
            {
                <tr>
                    <td>@i</td>
                    <td>@d.FruitName</td>
                    <td class="text-end-strong">@d.UnitPrice.ToString("N0")đ</td>
                    <td class="text-center">@d.Quantity @d.Unit</td>
                    <td class="text-end-strong">@((d.UnitPrice * d.Quantity).ToString("N0"))đ</td>
                </tr>
                i++;
            }
            @{
                var subtotal = Model.OrderDetails.Sum(x => x.UnitPrice * x.Quantity);
            }
            <tr>
                <td colspan="4" class="text-end-strong">Tạm tính:</td>
                <td class="text-end-strong">@subtotal.ToString("N0")đ</td>
            </tr>
            @if (Model.DiscountAmount > 0)
            {
                <tr>
                    <td colspan="4" class="text-end-strong text-danger">Giảm giá:</td>
                    <td class="text-end-strong text-danger">-@Model.DiscountAmount.ToString("N0")đ</td>
                </tr>
            }
            <tr class="total-row">
                <td colspan="4" class="text-end">TỔNG CỘNG:</td>
                <td class="text-end">@Model.TotalAmount.ToString("N0")đ</td>
            </tr>
            @if (Model.PaymentMethod == "Cash" && Model.AmountReceived.HasValue)
            {
                <tr>
                    <td colspan="4" class="text-end-strong">Tiền khách đưa:</td>
                    <td class="text-end-strong">@Model.AmountReceived.Value.ToString("N0")đ</td>
                </tr>
                <tr>
                    <td colspan="4" class="text-end-strong text-success">Tiền thừa:</td>
                    <td class="text-end-strong text-success">@Model.CashChange.ToString("N0")đ</td>
                </tr>
            }
        </tbody>
    </table>

    @if (!string.IsNullOrEmpty(Model.Note))
    {
        <div class="mt-3 muted"><strong>Ghi chú:</strong> @Model.Note</div>
    }

    <div class="text-center mt-5 muted">
        <div>Cảm ơn quý khách đã mua hàng tại FruitShop!</div>
        <div class="small mt-1">Hoá đơn in ngày @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</div>
    </div>
</div>

<script>
    // Tự động mở hộp thoại in khi URL có ?print=1
    if (new URLSearchParams(location.search).get('print') === '1') {
        window.addEventListener('load', () => setTimeout(() => window.print(), 300));
    }
</script>
</body>
</html>
