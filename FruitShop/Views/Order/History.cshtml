@model IEnumerable<FruitShop.Models.Entities.Order>
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
    Layout = "_LayoutUser";
}

<div class="container py-4">
    <!-- Page Header -->
    <div class="page-header animate-fade-in-up">
        <div>
            <h1 class="page-header-title mb-1">
                <i class="fas fa-history me-2" style="color:var(--primary);"></i>Lịch sử đơn hàng
            </h1>
            <p class="page-header-subtitle mb-0">Theo dõi và quản lý các đơn hàng của bạn</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state animate-fade-in-up">
            <div class="empty-state-icon">
                <i class="fas fa-box-open"></i>
            </div>
            <h5>Bạn chưa có đơn hàng nào</h5>
            <p>Hãy bắt đầu mua sắm và trải nghiệm những trái cây tươi ngon từ FruitShop!</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-success mt-3" style="border-radius:12px;padding:0.6rem 1.5rem;">
                <i class="fas fa-leaf me-2"></i>Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <!-- Stats -->
        <div class="row g-3 mb-4 animate-fade-in-up">
            <div class="col-md-3">
                <div class="mini-stat-card">
                    <i class="fas fa-shopping-bag" style="color:var(--primary);"></i>
                    <div>
                        <span style="color:var(--text-secondary);font-size:0.8rem;">Tổng đơn hàng</span><br/>
                        <strong style="font-size:1.1rem;">@Model.Count()</strong>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="mini-stat-card">
                    <i class="fas fa-clock" style="color:var(--warning);"></i>
                    <div>
                        <span style="color:var(--text-secondary);font-size:0.8rem;">Đang xử lý</span><br/>
                        <strong style="font-size:1.1rem;color:var(--warning);">@Model.Count(o => o.Status == "Pending" || o.Status == "Confirmed" || o.Status == "Shipping")</strong>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="mini-stat-card">
                    <i class="fas fa-check-circle" style="color:var(--success);"></i>
                    <div>
                        <span style="color:var(--text-secondary);font-size:0.8rem;">Đã hoàn thành</span><br/>
                        <strong style="font-size:1.1rem;color:var(--success);">@Model.Count(o => o.Status == "Delivered")</strong>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="mini-stat-card">
                    <i class="fas fa-money-bill" style="color:var(--info);"></i>
                    <div>
                        <span style="color:var(--text-secondary);font-size:0.8rem;">Tổng chi tiêu</span><br/>
                        <strong style="font-size:1.1rem;color:var(--info);">@Model.Sum(o => o.TotalAmount).ToString("N0")đ</strong>
                    </div>
                </div>
            </div>
        </div>

        <!-- Orders -->
        <div class="row g-3">
            @foreach (var order in Model)
            {
                var statusClass = order.Status switch {
                    "Pending"   => "status-pending",
                    "Confirmed" => "status-confirmed",
                    "Shipping"  => "status-shipping",
                    "Delivered" => "status-delivered",
                    "Cancelled" => "status-cancelled",
                    _ => ""
                };
                var statusText = order.Status switch {
                    "Pending"   => "Chờ xác nhận",
                    "Confirmed" => "Đã xác nhận",
                    "Shipping"  => "Đang giao",
                    "Delivered" => "Đã giao",
                    "Cancelled" => "Đã huỷ",
                    _ => order.Status
                };
                <div class="col-12 animate-fade-in-up">
                    <div class="card" style="border-left:4px solid var(--primary);border-radius:var(--border-radius);">
                        <div class="card-body">
                            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="d-flex align-items-center gap-3 mb-2">
                                        <h6 class="mb-0 fw-bold" style="font-size:1rem;">Đơn hàng #@order.OrderId</h6>
                                        <span class="status-pill @statusClass">@statusText</span>
                                    </div>
                                    <div class="d-flex flex-wrap gap-3" style="font-size:0.82rem;color:var(--text-secondary);">
                                        <span><i class="fas fa-calendar me-1" style="color:var(--text-muted);"></i>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                                        @if (!string.IsNullOrEmpty(order.ShippingAddress))
                                        {
                                            <span><i class="fas fa-map-marker-alt me-1" style="color:var(--text-muted);"></i>@order.ShippingAddress</span>
                                        }
                                        @if (!string.IsNullOrEmpty(order.PaymentMethod))
                                        {
                                            <span><i class="fas fa-credit-card me-1" style="color:var(--text-muted);"></i>@(order.PaymentMethod == "Cash" ? "Tiền mặt" : order.PaymentMethod == "Transfer" ? "Chuyển khoản" : "QR Code")</span>
                                        }
                                    </div>
                                </div>
                                <div class="text-md-end">
                                    <div class="fw-bold" style="font-size:1.3rem;color:var(--primary);">@order.TotalAmount.ToString("N0")đ</div>
                                    <div class="d-flex gap-2 mt-2 justify-content-md-end">
                                        <a asp-action="Details" asp-route-id="@order.OrderId"
                                           class="btn btn-outline-success btn-sm" style="border-radius:8px;font-weight:600;">
                                            <i class="fas fa-eye me-1"></i>Chi tiết
                                        </a>
                                        @if (order.Status == "Pending")
                                        {
                                            <form asp-action="Cancel" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@order.OrderId" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                                        onclick="return confirm('Bạn có chắc muốn huỷ đơn hàng này?')"
                                                        style="border-radius:8px;font-weight:600;">
                                                    <i class="fas fa-ban me-1"></i>Huỷ
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
