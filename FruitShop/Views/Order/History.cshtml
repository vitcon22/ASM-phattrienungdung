@model IEnumerable<FruitShop.Models.Entities.Order>
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
    Layout = "_LayoutUser";
}

<div class="container py-4">
    <h3 class="mb-4"><i class="fas fa-history me-2 text-success"></i>Lịch sử đơn hàng</h3>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-inbox fa-4x text-muted mb-3 d-block"></i>
            <h5 class="text-muted">Bạn chưa có đơn hàng nào</h5>
            <a asp-controller="Home" asp-action="Index" class="btn btn-success mt-3">
                Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var order in Model)
            {
                <div class="col-12">
                    <div class="card order-history-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-1">
                                        Đơn hàng #@order.OrderId
                                        <span class="badge bg-@order.GetStatusBadge() ms-2">@order.GetStatusText()</span>
                                    </h6>
                                    <div class="text-muted small mb-1">
                                        <i class="fas fa-calendar me-1"></i>
                                        @order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                    @if (!string.IsNullOrEmpty(order.ShippingAddress))
                                    {
                                        <div class="text-muted small">
                                            <i class="fas fa-map-marker-alt me-1"></i>@order.ShippingAddress
                                        </div>
                                    }
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold text-success fs-5">@order.TotalAmount.ToString("N0")đ</div>
                                    <div class="d-flex gap-2 mt-2 justify-content-end">
                                        <a asp-action="Details" asp-route-id="@order.OrderId"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye me-1"></i>Chi tiết
                                        </a>
                                        @if (order.Status == "Pending")
                                        {
                                            <form asp-action="Cancel" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@order.OrderId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Bạn có chắc muốn huỷ đơn hàng này?')">
                                                    <i class="fas fa-ban me-1"></i>Huỷ
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
