@model List<FruitShop.Models.ViewModels.CartItemViewModel>
@{
    ViewData["Title"] = "Giỏ hàng";
    Layout = "_LayoutUser";
    decimal total = Model.Sum(x => x.Subtotal);
}

<div class="container py-4">
    <h3 class="mb-4"><i class="fas fa-shopping-cart me-2 text-success"></i>Giỏ hàng của bạn</h3>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-shopping-cart fa-4x text-muted mb-3 d-block"></i>
            <h5 class="text-muted">Giỏ hàng trống</h5>
            <a asp-controller="Home" asp-action="Index" class="btn btn-success mt-3">
                <i class="fas fa-arrow-left me-2"></i>Tiếp tục mua sắm
            </a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-body p-0">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th class="text-center">Đơn giá</th>
                                    <th class="text-center" style="width:150px">Số lượng</th>
                                    <th class="text-end">Thành tiền</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="~/images/fruits/@(item.ImageUrl ?? "default.jpg")"
                                                     class="rounded me-3" style="width:60px;height:60px;object-fit:cover;"
                                                     onerror="this.src='/images/fruits/default.jpg'" />
                                                <div>
                                                    <div class="fw-semibold">@item.FruitName</div>
                                                    <small class="text-muted">@item.UnitPrice.ToString("N0")đ/@item.Unit</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">@item.UnitPrice.ToString("N0")đ</td>
                                        <td>
                                            <form asp-action="UpdateCart" method="post" class="d-flex align-items-center justify-content-center gap-1">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="fruitId" value="@item.FruitId" />
                                                <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                                        class="btn btn-sm btn-outline-secondary">−</button>
                                                <span class="px-2 fw-semibold">@item.Quantity</span>
                                                <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                                        class="btn btn-sm btn-outline-secondary"
                                                        @(item.Quantity >= item.StockQuantity ? "disabled" : "")>+</button>
                                            </form>
                                        </td>
                                        <td class="text-end fw-bold text-success">@item.Subtotal.ToString("N0")đ</td>
                                        <td>
                                            <form asp-action="RemoveFromCart" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="fruitId" value="@item.FruitId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="mt-3">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Tiếp tục mua sắm
                    </a>
                </div>
            </div>

            <!-- ORDER SUMMARY -->
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h6 class="mb-0">Tóm tắt đơn hàng</h6>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Tạm tính (@Model.Sum(x=>x.Quantity) món)</span>
                            <span>@total.ToString("N0")đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Phí giao hàng</span>
                            <span class="text-success">Miễn phí</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between fw-bold fs-5">
                            <span>Tổng cộng</span>
                            <span class="text-success">@total.ToString("N0")đ</span>
                        </div>
                        <a asp-action="Checkout" class="btn btn-success w-100 mt-3 btn-lg">
                            <i class="fas fa-credit-card me-2"></i>Tiến hành đặt hàng
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
