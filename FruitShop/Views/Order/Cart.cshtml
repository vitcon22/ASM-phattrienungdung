@model List<FruitShop.Models.ViewModels.CartItemViewModel>
@{
    ViewData["Title"] = "Giỏ hàng";
    Layout = "_LayoutUser";
    decimal total = Model.Sum(x => x.Subtotal);
}

<div class="container py-4">
    <!-- Page Header -->
    <div class="page-header animate-fade-in-up">
        <div>
            <h1 class="page-header-title mb-1">
                <i class="fas fa-shopping-cart me-2" style="color:var(--primary);"></i>Giỏ hàng của bạn
            </h1>
            <p class="page-header-subtitle mb-0">@(Model.Any() ? $"Bạn có {Model.Sum(x => x.Quantity)} sản phẩm trong giỏ" : "Giỏ hàng trống")</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state animate-fade-in-up">
            <div class="empty-state-icon">
                <i class="fas fa-shopping-cart"></i>
            </div>
            <h5>Giỏ hàng trống</h5>
            <p>Hãy khám phá cửa hàng và thêm những trái cây tươi ngon vào giỏ hàng nhé!</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-success mt-3" style="border-radius:12px;padding:0.6rem 1.5rem;">
                <i class="fas fa-leaf me-2"></i>Khám phá cửa hàng
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Cart Items -->
            <div class="col-lg-8">
                <div class="card animate-fade-in-up">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h6 class="mb-0 fw-bold">
                            <i class="fas fa-box-open me-2" style="color:var(--primary);"></i>Sản phẩm trong giỏ
                        </h6>
                        <span class="badge" style="background:var(--primary-pale);color:var(--primary-dark);border-radius:50px;">@Model.Sum(x => x.Quantity) sản phẩm</span>
                    </div>
                    <div class="card-body p-0">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th style="padding:0.75rem 1rem;border-bottom:1px solid var(--border);">Sản phẩm</th>
                                    <th class="text-center" style="padding:0.75rem 1rem;border-bottom:1px solid var(--border);">Đơn giá</th>
                                    <th class="text-center" style="padding:0.75rem 1rem;border-bottom:1px solid var(--border);width:140px;">Số lượng</th>
                                    <th class="text-end" style="padding:0.75rem 1rem;border-bottom:1px solid var(--border);">Thành tiền</th>
                                    <th style="padding:0.75rem 1rem;border-bottom:1px solid var(--border);width:50px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr class="cart-item-row">
                                        <td style="padding:1rem;">
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="~/images/fruits/@(item.ImageUrl ?? "default.jpg")"
                                                     class="cart-item-img"
                                                     onerror="this.src='/images/fruits/default.jpg'" />
                                                <div>
                                                    <div class="fw-semibold" style="font-size:0.9rem;">@item.FruitName</div>
                                                    <small style="color:var(--text-muted);">@item.UnitPrice.ToString("N0")đ/@item.Unit</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center" style="font-weight:600;color:var(--primary);">@item.UnitPrice.ToString("N0")đ</td>
                                        <td>
                                            <form asp-action="UpdateCart" method="post" class="d-flex align-items-center justify-content-center gap-1">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="fruitId" value="@item.FruitId" />
                                                <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                                        class="btn btn-sm" style="width:28px;height:28px;padding:0;border-radius:8px;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;background:var(--bg-card);">
                                                    −
                                                </button>
                                                <span class="px-2 fw-bold" style="min-width:32px;text-align:center;">@item.Quantity</span>
                                                <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                                        class="btn btn-sm" style="width:28px;height:28px;padding:0;border-radius:8px;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;background:var(--bg-card);@(item.Quantity >= item.StockQuantity ? "opacity:0.4;" : "")"
                                                        @(item.Quantity >= item.StockQuantity ? "disabled" : "")>
                                                    +
                                                </button>
                                            </form>
                                        </td>
                                        <td class="text-end">
                                            <span style="color:var(--primary);font-weight:700;font-size:0.95rem;">@item.Subtotal.ToString("N0")đ</span>
                                        </td>
                                        <td>
                                            <form asp-action="RemoveFromCart" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="fruitId" value="@item.FruitId" />
                                                <button type="submit" class="btn-action-delete" title="Xóa khỏi giỏ" style="width:30px;height:30px;padding:0;display:flex;align-items:center;justify-content:center;border-radius:8px;">
                                                    <i class="fas fa-trash" style="font-size:0.75rem;"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="mt-3">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary" style="border-radius:10px;padding:0.5rem 1.1rem;">
                        <i class="fas fa-arrow-left me-2"></i>Tiếp tục mua sắm
                    </a>
                </div>
            </div>

            <!-- ORDER SUMMARY -->
            <div class="col-lg-4">
                <div class="cart-summary-card animate-fade-in-up stagger-2">
                    <h6 class="fw-bold mb-3" style="font-size:1rem;">
                        <i class="fas fa-receipt me-2" style="color:var(--primary);"></i>Tóm tắt đơn hàng
                    </h6>
                    <div class="d-flex justify-content-between mb-2" style="font-size:0.88rem;">
                        <span style="color:var(--text-secondary);">Tạm tính (<strong>@Model.Sum(x=>x.Quantity)</strong> sản phẩm)</span>
                        <span class="fw-semibold">@total.ToString("N0")đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2" style="font-size:0.88rem;">
                        <span style="color:var(--text-secondary);">Phí giao hàng</span>
                        <span style="color:var(--primary);font-weight:600;">Miễn phí</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2" style="font-size:0.88rem;">
                        <span style="color:var(--text-secondary);">Giảm giá</span>
                        <span style="color:var(--text-muted);">—</span>
                    </div>
                    <hr style="margin:0.75rem 0;" />
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="fw-bold" style="font-size:1.1rem;">Tổng cộng</span>
                        <span style="color:var(--primary);font-weight:800;font-size:1.3rem;">@total.ToString("N0")đ</span>
                    </div>
                    <a asp-action="Checkout" class="btn btn-success w-100" style="border-radius:12px;padding:0.7rem;font-weight:700;font-size:0.95rem;">
                        <i class="fas fa-credit-card me-2"></i>Tiến hành đặt hàng
                    </a>
                    <!-- Trust badges -->
                    <div class="mt-3 pt-3" style="border-top:1px solid var(--border);">
                        <div class="d-flex gap-3 justify-content-center">
                            <div class="text-center" style="flex:1;">
                                <i class="fas fa-shield-alt" style="color:var(--primary);font-size:1.1rem;"></i>
                                <div style="font-size:0.68rem;color:var(--text-muted);margin-top:2px;">Bảo mật</div>
                            </div>
                            <div class="text-center" style="flex:1;">
                                <i class="fas fa-truck" style="color:var(--primary);font-size:1.1rem;"></i>
                                <div style="font-size:0.68rem;color:var(--text-muted);margin-top:2px;">Giao nhanh</div>
                            </div>
                            <div class="text-center" style="flex:1;">
                                <i class="fas fa-undo" style="color:var(--primary);font-size:1.1rem;"></i>
                                <div style="font-size:0.68rem;color:var(--text-muted);margin-top:2px;">Đổi trả</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
