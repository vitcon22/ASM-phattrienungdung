@using FruitShop.Helpers
@model PagedList<FruitShop.Models.Entities.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "_Layout";
}
@section Breadcrumb {
    <li class="breadcrumb-item active">Đơn hàng</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="page-title"><i class="fas fa-shopping-bag me-2 text-success"></i>Quản lý đơn hàng</h4>
    <span class="badge bg-success fs-6">Tổng: @Model.TotalCount đơn</span>
</div>

<!-- Bộ lọc -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Trạng thái</label>
                <select name="status" class="form-select">
                    <option value="">-- Tất cả --</option>
                    @foreach (var s in new[] { "Pending","Confirmed","Shipping","Delivered","Cancelled" })
                    {
                        var statusText = s switch { "Pending"=>"Chờ xác nhận","Confirmed"=>"Đã xác nhận","Shipping"=>"Đang giao","Delivered"=>"Đã giao","Cancelled"=>"Đã huỷ",_=>s };
                        bool isSelected = ViewBag.Status == s;
                        if (isSelected) { <option value="@s" selected>@statusText</option> }
                        else            { <option value="@s">@statusText</option> }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Từ ngày</label>
                <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Đến ngày</label>
                <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate" />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-success flex-fill"><i class="fas fa-search"></i></button>
                <a asp-action="Index" class="btn btn-outline-secondary flex-fill"><i class="fas fa-redo"></i></a>
            </div>
        </form>
    </div>
</div>

<!-- Danh sách -->
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Mã ĐH</th>
                    <th>Khách hàng</th>
                    <th>Ngày đặt</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center">Trạng thái</th>
                    <th>Địa chỉ</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="7" class="text-center py-4 text-muted">Không có đơn hàng nào</td></tr>
                }
                @foreach (var order in Model.Items)
                {
                    <tr>
                        <td><strong>#@order.OrderId</strong></td>
                        <td>@order.CustomerName</td>
                        <td class="small text-muted">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-end fw-bold text-success">@order.TotalAmount.ToString("N0")đ</td>
                        <td class="text-center">
                            <span class="badge bg-@order.GetStatusBadge()">@order.GetStatusText()</span>
                        </td>
                        <td class="small text-muted text-truncate" style="max-width:150px">
                            @(order.ShippingAddress ?? "—")
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@order.OrderId"
                               class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye"></i> Xem
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage-1)"
                   asp-route-status="@ViewBag.Status"><i class="fas fa-chevron-left"></i></a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i"
                       asp-route-status="@ViewBag.Status">@i</a>
                </li>
            }
            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage+1)"
                   asp-route-status="@ViewBag.Status"><i class="fas fa-chevron-right"></i></a>
            </li>
        </ul>
    </nav>
}
