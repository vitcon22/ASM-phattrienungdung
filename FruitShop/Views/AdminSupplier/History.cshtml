@model List<FruitShop.Models.Entities.Batch>
@{
    ViewData["Title"] = "Lịch sử nhập hàng";
    Layout = "_Layout";
    var supplier = ViewBag.Supplier as FruitShop.Models.Entities.Supplier;
}
@section Breadcrumb {
    <li class="breadcrumb-item"><a href="@Url.Action("Index")">Nhà cung cấp</a></li>
    <li class="breadcrumb-item active">Lịch sử nhập hàng</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="page-title mb-0">
            <i class="fas fa-history me-2 text-primary"></i>Lịch sử nhập hàng
        </h4>
        <small class="text-muted">Nhà cung cấp: <strong>@supplier?.SupplierName</strong>
            @if (!string.IsNullOrEmpty(supplier?.Phone))
            {
                <span class="ms-2"><i class="fas fa-phone me-1"></i>@supplier.Phone</span>
            }
        </small>
    </div>
    <div class="btn-group">
        <a href="@Url.Action("PriceComparison")" class="btn btn-outline-info btn-sm">
            <i class="fas fa-balance-scale me-1"></i>So sánh giá
        </a>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left me-1"></i>Quay lại
        </a>
    </div>
</div>

<!-- Tổng kết -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 bg-primary text-white text-center p-3">
            <div class="fs-4 fw-bold">@ViewBag.TotalBatches</div>
            <div class="small">Tổng lô nhập</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 bg-success text-white text-center p-3">
            <div class="fs-4 fw-bold">@((int)ViewBag.TotalQty)</div>
            <div class="small">Tổng số lượng nhập</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 bg-warning text-dark text-center p-3">
            <div class="fs-5 fw-bold">@(((decimal)ViewBag.TotalValue).ToString("N0"))đ</div>
            <div class="small">Tổng giá trị nhập</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 bg-info text-white text-center p-3">
            <div class="fs-6 fw-bold">
                @(ViewBag.LastImport != null
                    ? ((DateTime)ViewBag.LastImport).ToString("dd/MM/yyyy")
                    : "—")
            </div>
            <div class="small">Lần nhập gần nhất</div>
        </div>
    </div>
</div>

<!-- Bảng lịch sử -->
<div class="card shadow-sm">
    <div class="card-header bg-white fw-bold">
        <i class="fas fa-list me-2"></i>Chi tiết lịch sử nhập hàng
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã lô</th>
                        <th>Sản phẩm</th>
                        <th>Ngày nhập</th>
                        <th>Hạn sử dụng</th>
                        <th class="text-end">Đơn giá nhập</th>
                        <th class="text-center">SL nhập</th>
                        <th class="text-end">Tổng giá trị</th>
                        <th class="text-center">Còn lại</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model)
                    {
                        var expired = b.ExpiryDate < DateTime.Now;
                        <tr class="@(expired ? "text-muted" : "")">
                            <td><code>@b.BatchCode</code></td>
                            <td>@b.FruitName</td>
                            <td>@b.ImportDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                @b.ExpiryDate.ToString("dd/MM/yyyy")
                                @if (expired)
                                {
                                    <span class="badge bg-danger ms-1">Hết hạn</span>
                                }
                            </td>
                            <td class="text-end">@b.BuyPrice.ToString("N0")đ</td>
                            <td class="text-center">@b.Quantity</td>
                            <td class="text-end">@((b.BuyPrice * b.Quantity).ToString("N0"))đ</td>
                            <td class="text-center">
                                <span class="badge @(b.RemainingQty == 0 ? "bg-secondary" : "bg-success")">
                                    @b.RemainingQty
                                </span>
                            </td>
                            <td>
                                <a href="@Url.Action("PrintReceipt", "Batch", new { id = b.BatchId })"
                                   class="btn btn-sm btn-outline-secondary" title="In phiếu nhập kho">
                                    <i class="fas fa-print"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="9" class="text-center text-muted py-4">Nhà cung cấp này chưa có lịch sử nhập hàng.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
