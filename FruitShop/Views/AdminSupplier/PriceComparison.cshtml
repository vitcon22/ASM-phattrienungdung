@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "So sánh giá nhập";
    Layout = "_Layout";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a href="@Url.Action("Index", "AdminSupplier")">Nhà cung cấp</a></li>
    <li class="breadcrumb-item active">So sánh giá nhập</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="page-title mb-0">
        <i class="fas fa-balance-scale text-info me-2"></i>So sánh giá nhập theo nhà cung cấp
    </h4>
    <a href="@Url.Action("Index", "AdminSupplier")" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i>Quay lại
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom py-3">
        <h6 class="mb-0 fw-bold"><i class="fas fa-list me-2 text-primary"></i>Chi tiết giá nhập</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Sản phẩm</th>
                        <th>ĐVT</th>
                        <th>Nhà cung cấp</th>
                        <th class="text-center">Số lô</th>
                        <th class="text-center">Tổng lượng nhập</th>
                        <th class="text-end text-success">Giá Min</th>
                        <th class="text-end text-danger">Giá Max</th>
                        <th class="text-end text-primary">Giá TB</th>
                        <th class="text-center">Lần nhập cuối</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.FruitName</td>
                            <td>@item.Unit</td>
                            <td>
                                <a href="@Url.Action("History", "AdminSupplier", new { id = item.SupplierId })" class="text-decoration-none">
                                    @item.SupplierName
                                </a>
                            </td>
                            <td class="text-center">@item.BatchCount</td>
                            <td class="text-center">@item.TotalQtyImported</td>
                            <td class="text-end fw-bold text-success">@((item.MinBuyPrice as decimal?)?.ToString("N0") ?? "0")đ</td>
                            <td class="text-end fw-bold text-danger">@((item.MaxBuyPrice as decimal?)?.ToString("N0") ?? "0")đ</td>
                            <td class="text-end fw-bold text-primary">@((item.AvgBuyPrice as decimal?)?.ToString("N0") ?? "0")đ</td>
                            <td class="text-center">
                                @(item.LastImportDate != null ? ((DateTime)item.LastImportDate).ToString("dd/MM/yyyy") : "—")
                            </td>
                            <td class="text-end">
                                <a href="@Url.Action("History", "AdminSupplier", new { id = item.SupplierId })" class="btn btn-sm btn-outline-primary" title="Xem lịch sử">
                                    <i class="fas fa-history"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-4">Chưa có dữ liệu nhập hàng.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
