@model FruitShop.Models.Entities.Batch
@{
    ViewData["Title"] = "Nhập lô hàng mới";
    Layout = "_Layout";
}
@section Breadcrumb {
    <li class="breadcrumb-item"><a href="@Url.Action("Index")">Lô hàng</a></li>
    <li class="breadcrumb-item active">Nhập lô mới</li>
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="fas fa-boxes me-2"></i>Nhập lô hàng mới</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="BatchCode" class="form-label fw-bold">Mã lô hàng <span class="text-danger">*</span></label>
                            <input asp-for="BatchCode" class="form-control" placeholder="VD: BATCH-20260401-01" required />
                            <span asp-validation-for="BatchCode" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FruitId" class="form-label fw-bold">Sản phẩm <span class="text-danger">*</span></label>
                            <select asp-for="FruitId" asp-items="@ViewBag.Fruits" class="form-select" required>
                                <option value="">-- Chọn sản phẩm --</option>
                            </select>
                            <span asp-validation-for="FruitId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ImportDate" class="form-label fw-bold">Ngày nhập</label>
                            <input asp-for="ImportDate" type="date" class="form-control"
                                   value="@Model.ImportDate.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ManufactureDate" class="form-label fw-bold">Ngày sản xuất</label>
                            <input asp-for="ManufactureDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ExpiryDate" class="form-label fw-bold">Hạn sử dụng <span class="text-danger">*</span></label>
                            <input asp-for="ExpiryDate" type="date" class="form-control"
                                   value="@Model.ExpiryDate.ToString("yyyy-MM-dd")" required />
                            <span asp-validation-for="ExpiryDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BuyPrice" class="form-label fw-bold">Giá nhập (đ/đơn vị) <span class="text-danger">*</span></label>
                            <input asp-for="BuyPrice" type="number" min="0" step="100" class="form-control" placeholder="VD: 50000" required />
                            <span asp-validation-for="BuyPrice" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Quantity" class="form-label fw-bold">Số lượng nhập <span class="text-danger">*</span></label>
                            <input asp-for="Quantity" type="number" min="1" class="form-control" placeholder="VD: 100" required />
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                        </div>
                    </div>
                    <hr class="my-3" />
                    <div class="alert alert-info small">
                        <i class="fas fa-info-circle me-1"></i>
                        Khi nhập lô hàng, hệ thống sẽ tự động cộng số lượng vào tồn kho sản phẩm và ghi log kho.
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save me-1"></i>Xác nhận nhập lô
                        </button>
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
