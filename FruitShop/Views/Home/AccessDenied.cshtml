@{
    ViewData["Title"] = "Không có quyền truy cập";
    Layout = "_LayoutUser";
}

<div class="container py-5 text-center">
    <div class="py-5">
        <div class="mb-4">
            <i class="fas fa-lock fa-5x text-danger"></i>
        </div>
        <h1 class="display-4 fw-bold text-danger">403</h1>
        <h3 class="text-muted mb-3">Không có quyền truy cập</h3>
        <p class="lead text-muted">
            Bạn không có quyền xem trang này. Vui lòng đăng nhập với tài khoản có quyền phù hợp.
        </p>
        <div class="d-flex gap-3 justify-content-center mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-success btn-lg">
                <i class="fas fa-home me-2"></i>Trang chủ
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-lg">
                <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập lại
            </a>
        </div>
    </div>
</div>
