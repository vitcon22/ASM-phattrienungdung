@using FruitShop.Helpers
@model PagedList<FruitShop.Models.Entities.Category>
@{
    ViewData["Title"] = "Danh mục trái cây";
    Layout = "_Layout";
}
@section Breadcrumb {
    <li class="breadcrumb-item active">Danh mục</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="page-title"><i class="fas fa-tags me-2 text-success"></i>Quản lý Danh mục</h4>
    <a asp-action="Create" class="btn btn-success">
        <i class="fas fa-plus me-2"></i>Thêm danh mục
    </a>
</div>

<!-- Tìm kiếm -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-8">
                <label class="form-label">Tìm kiếm theo tên</label>
                <input type="text" name="keyword" class="form-control" value="@ViewBag.Keyword"
                       placeholder="Nhập tên danh mục..." />
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-success flex-fill">
                    <i class="fas fa-search me-1"></i>Tìm kiếm
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                    <i class="fas fa-redo me-1"></i>Làm mới
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Danh sách -->
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:50px">#</th>
                    <th>Tên danh mục</th>
                    <th>Mô tả</th>
                    <th class="text-center">Số sản phẩm</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center" style="width:150px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="6" class="text-center py-4 text-muted">Không có danh mục nào</td></tr>
                }
                @{int stt = (Model.CurrentPage - 1) * Model.PageSize + 1;}
                @foreach (var cat in Model.Items)
                {
                    <tr>
                        <td class="text-muted">@stt</td>
                        <td><strong>@cat.CategoryName</strong></td>
                        <td class="text-muted">@(cat.Description ?? "—")</td>
                        <td class="text-center">
                            <span class="badge bg-primary rounded-pill">@cat.FruitCount</span>
                        </td>
                        <td class="text-center">
                            @if (cat.IsActive)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Ẩn</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@cat.CategoryId"
                               class="btn btn-sm btn-outline-primary me-1" title="Sửa">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@cat.CategoryId"
                               class="btn btn-sm btn-outline-danger" title="Xóa">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                    stt++;
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Phân trang -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(Model.CurrentPage - 1)" asp-route-keyword="@ViewBag.Keyword">
                    <i class="fas fa-chevron-left"></i>
                </a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i" asp-route-keyword="@ViewBag.Keyword">@i</a>
                </li>
            }
            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(Model.CurrentPage + 1)" asp-route-keyword="@ViewBag.Keyword">
                    <i class="fas fa-chevron-right"></i>
                </a>
            </li>
        </ul>
        <p class="text-center text-muted small">
            Hiển thị @Model.Items.Count() / @Model.TotalCount danh mục
        </p>
    </nav>
}
