@model FruitShop.Models.Entities.Category
@{
    ViewData["Title"] = "Xóa danh mục";
    Layout = "_Layout";
}
@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-action="Index">Danh mục</a></li>
    <li class="breadcrumb-item active">Xóa</li>
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="fas fa-exclamation-triangle me-2"></i>Xác nhận xóa danh mục</h5>
            </div>
            <div class="card-body text-center py-4">
                <i class="fas fa-trash-alt fa-3x text-danger mb-3"></i>
                <h5>Bạn có chắc muốn xóa danh mục này?</h5>
                <p class="lead"><strong>@Model.CategoryName</strong></p>
                @if (Model.FruitCount > 0)
                {
                    <div class="alert alert-warning">
                        <i class="fas fa-warning me-2"></i>
                        Danh mục này có <strong>@Model.FruitCount</strong> sản phẩm. Không thể xóa!
                    </div>
                }
                else
                {
                    <p class="text-muted">Hành động này sẽ ẩn danh mục khỏi hệ thống (xóa mềm).</p>
                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.CategoryId" />
                        <div class="d-flex gap-3 justify-content-center">
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="fas fa-trash me-2"></i>Xác nhận xóa
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="fas fa-arrow-left me-2"></i>Hủy
                            </a>
                        </div>
                    </form>
                }
                @if (Model.FruitCount > 0)
                {
                    <a asp-action="Index" class="btn btn-outline-secondary mt-3">
                        <i class="fas fa-arrow-left me-2"></i>Quay lại
                    </a>
                }
            </div>
        </div>
    </div>
</div>
