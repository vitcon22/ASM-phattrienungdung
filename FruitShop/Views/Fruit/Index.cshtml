@using FruitShop.Helpers
@model PagedList<FruitShop.Models.Entities.Fruit>
@{
    ViewData["Title"] = "Quản lý Trái cây";
    Layout = "_Layout";
    var userRole = ViewBag.UserRole?.ToString() ?? "";
}
@section Breadcrumb {
    <li class="breadcrumb-item active">Trái cây</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="page-title"><i class="fas fa-lemon me-2 text-success"></i>Quản lý Trái cây</h4>
    @if (userRole == "Admin" || userRole == "Staff")
    {
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus me-2"></i>Thêm trái cây
        </a>
    }
</div>

<!-- Tìm kiếm và lọc -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Tìm kiếm</label>
                <input type="text" name="keyword" class="form-control" value="@ViewBag.Keyword"
                       placeholder="Tên trái cây..." />
            </div>
            <div class="col-md-4">
                <label class="form-label">Danh mục</label>
                @Html.DropDownList("categoryId", (SelectList)ViewBag.Categories,
                    "-- Tất cả danh mục --", new { @class = "form-select" })
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-success flex-fill">
                    <i class="fas fa-search me-1"></i>Tìm
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                    <i class="fas fa-redo me-1"></i>Reset
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:60px">#</th>
                    <th style="width:70px">Ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Danh mục</th>
                    <th class="text-end">Giá</th>
                    <th class="text-center">Tồn kho</th>
                    <th>Xuất xứ</th>
                    <th class="text-center">Trạng thái</th>
                    @if (userRole == "Admin" || userRole == "Staff")
                    {
                        <th class="text-center" style="width:130px">Thao tác</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="9" class="text-center py-4 text-muted">Không có sản phẩm nào</td></tr>
                }
                @{int stt = (Model.CurrentPage - 1) * Model.PageSize + 1;}
                @foreach (var fruit in Model.Items)
                {
                    <tr>
                        <td class="text-muted">@stt</td>
                        <td>
                            <img src="~/images/fruits/@fruit.GetImageUrl()"
                                 alt="@fruit.FruitName"
                                 class="fruit-thumb"
                                 onerror="this.src='/images/fruits/default.jpg'" />
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@fruit.FruitId"
                               class="fw-semibold text-decoration-none">@fruit.FruitName</a>
                            <div class="small text-muted">@fruit.Unit</div>
                        </td>
                        <td><span class="badge bg-light text-dark">@fruit.CategoryName</span></td>
                        <td class="text-end fw-bold text-success">@fruit.Price.ToString("N0")đ</td>
                        <td class="text-center">
                            @if (fruit.StockQuantity < 10)
                            {
                                <span class="badge bg-danger">@fruit.StockQuantity</span>
                            }
                            else
                            {
                                <span class="badge bg-success">@fruit.StockQuantity</span>
                            }
                        </td>
                        <td class="small text-muted">@(fruit.Origin ?? "—")</td>
                        <td class="text-center">
                            <span class="badge @(fruit.IsActive ? "bg-success" : "bg-secondary")">
                                @(fruit.IsActive ? "Đang bán" : "Ẩn")
                            </span>
                        </td>
                        @if (userRole == "Admin" || userRole == "Staff")
                        {
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@fruit.FruitId"
                                   class="btn btn-sm btn-outline-primary me-1" title="Sửa">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@fruit.FruitId"
                                   class="btn btn-sm btn-outline-danger" title="Xóa">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        }
                    </tr>
                    stt++;
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Phân trang -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(Model.CurrentPage - 1)"
                   asp-route-keyword="@ViewBag.Keyword"
                   asp-route-categoryId="@ViewBag.CategoryId">
                    <i class="fas fa-chevron-left"></i>
                </a>
            </li>
            @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-keyword="@ViewBag.Keyword"
                       asp-route-categoryId="@ViewBag.CategoryId">@i</a>
                </li>
            }
            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(Model.CurrentPage + 1)"
                   asp-route-keyword="@ViewBag.Keyword"
                   asp-route-categoryId="@ViewBag.CategoryId">
                    <i class="fas fa-chevron-right"></i>
                </a>
            </li>
        </ul>
        <p class="text-center text-muted small">Tổng @Model.TotalCount sản phẩm</p>
    </nav>
}
