@using FruitShop.Helpers
@model PagedList<FruitShop.Models.Entities.Fruit>
@{
    ViewData["Title"] = "Quản lý Trái cây";
    Layout = "_Layout";
    var userRole = ViewBag.UserRole?.ToString() ?? "";
}
@section Breadcrumb {
    <li class="breadcrumb-item active">Trái cây</li>
}

<!-- Page Header -->
<div class="page-header animate-fade-in-up">
    <div>
        <h1 class="page-header-title mb-1">
            <i class="fas fa-lemon me-2" style="color:var(--primary);"></i>Quản lý Trái cây
        </h1>
        <p class="page-header-subtitle">@(Model.TotalCount) sản phẩm trong cửa hàng</p>
    </div>
    @if (userRole == "Admin" || userRole == "Staff")
    {
        <div class="d-flex gap-2">
            <a asp-action="ExportCsv" class="btn" style="border:1.5px solid var(--border);border-radius:10px;color:var(--text-secondary);font-weight:600;padding:0.5rem 1rem;">
                <i class="fas fa-file-csv me-1" style="color:var(--info);"></i>Xuất CSV
            </a>
            <a asp-action="ImportExcel" class="btn" style="border:1.5px solid var(--border);border-radius:10px;color:var(--text-secondary);font-weight:600;padding:0.5rem 1rem;">
                <i class="fas fa-file-excel me-1" style="color:var(--success);"></i>Nhập Excel
            </a>
            <a asp-action="Create" class="btn btn-success" style="border-radius:10px;padding:0.5rem 1.2rem;">
                <i class="fas fa-plus me-2"></i>Thêm trái cây
            </a>
        </div>
    }
</div>

<!-- Search & Filter -->
<div class="card mb-4 animate-fade-in-up">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Tìm kiếm</label>
                <input type="text" name="keyword" class="form-control" value="@ViewBag.Keyword"
                       id="keywordInput" autocomplete="off"
                       placeholder="Tên trái cây hoặc xuất xứ..." />
                <div id="suggestBox" class="list-group position-absolute shadow" style="z-index:1000;max-width:400px;border-radius:10px;"></div>
            </div>
            <div class="col-md-3">
                <label class="form-label">Danh mục</label>
                @Html.DropDownList("categoryId", (SelectList)ViewBag.Categories,
                    "-- Tất cả danh mục --", new { @class = "form-select" })
            </div>
            <div class="col-md-3">
                <label class="form-label">Xuất xứ</label>
                <input type="text" name="origin" class="form-control" value="@ViewBag.Origin"
                       placeholder="VD: Việt Nam, Thái Lan..." />
            </div>
            <div class="col-md-2">
                <label class="form-label">Giá từ</label>
                <input type="number" name="minPrice" class="form-control" value="@ViewBag.MinPrice"
                       min="0" step="1000" placeholder="0đ" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Giá đến</label>
                <input type="number" name="maxPrice" class="form-control" value="@ViewBag.MaxPrice"
                       min="0" step="1000" placeholder="999.000đ" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Tồn kho</label>
                <select name="stockStatus" class="form-select">
                    <option value="">-- Tất cả --</option>
                    <option value="in"  selected="@(ViewBag.StockStatus as string == "in")">Còn hàng (≥ MinStock)</option>
                    <option value="low" selected="@(ViewBag.StockStatus as string == "low")">Sắp hết (&lt; MinStock)</option>
                    <option value="out" selected="@(ViewBag.StockStatus as string == "out")">Hết hàng</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2 align-items-end">
                <button type="submit" class="btn btn-success flex-fill" style="border-radius:10px;">
                    <i class="fas fa-search me-1"></i>Tìm kiếm
                </button>
                <a asp-action="Index" class="btn" style="border:1.5px solid var(--border);border-radius:10px;color:var(--text-secondary);">
                    <i class="fas fa-redo"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Data Table -->
<div class="data-table-wrapper animate-fade-in-up">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th style="width:50px;">#</th>
                <th style="width:70px;">Ảnh</th>
                <th>Tên sản phẩm</th>
                <th>Danh mục</th>
                <th class="text-end">Giá</th>
                <th class="text-center">Tồn kho</th>
                <th>Xuất xứ</th>
                <th class="text-center">Trạng thái</th>
                @if (userRole == "Admin" || userRole == "Staff")
                {
                    <th class="text-center" style="width:100px;">Thao tác</th>
                }
            </tr>
        </thead>
        <tbody>
            @if (!Model.Items.Any())
            {
                <tr><td colspan="@(userRole == "Admin" || userRole == "Staff" ? 9 : 8)" class="text-center py-5">
                    <div class="empty-state-icon mx-auto" style="margin-bottom:0.75rem;">
                        <i class="fas fa-lemon"></i>
                    </div>
                    <p class="text-muted mb-0">Không có sản phẩm nào</p>
                </td></tr>
            }
            @{int stt = (Model.CurrentPage - 1) * Model.PageSize + 1;}
            @foreach (var fruit in Model.Items)
            {
                <tr>
                    <td class="text-muted" style="font-size:0.82rem;">@stt</td>
                    <td>
                        <img src="~/images/fruits/@fruit.GetImageUrl()"
                             alt="@fruit.FruitName"
                             class="fruit-thumb"
                             onerror="this.src='/images/fruits/default.jpg'" />
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@fruit.FruitId"
                           class="fw-semibold text-decoration-none" style="color:var(--text-primary);">@fruit.FruitName</a>
                        <div class="small text-muted">@fruit.Unit</div>
                    </td>
                    <td><span class="badge" style="background:var(--primary-pale);color:var(--primary-dark);border-radius:50px;font-size:0.72rem;">@fruit.CategoryName</span></td>
                    <td class="text-end fw-bold" style="color:var(--primary);">@fruit.Price.ToString("N0")đ</td>
                    <td class="text-center">
                        @if (fruit.StockQuantity < fruit.MinStock)
                        {
                            <span class="badge" style="background:#FEE2E2;color:#991B1B;border-radius:50px;">@fruit.StockQuantity</span>
                        }
                        else if (fruit.StockQuantity == 0)
                        {
                            <span class="badge" style="background:#F3F4F6;color:#6B7280;border-radius:50px;">Hết hàng</span>
                        }
                        else
                        {
                            <span class="badge" style="background:var(--primary-pale);color:#065F46;border-radius:50px;">@fruit.StockQuantity</span>
                        }
                    </td>
                    <td class="small text-muted">@(fruit.Origin ?? "—")</td>
                    <td class="text-center">
                        <span class="status-pill @(fruit.IsActive ? "status-delivered" : "status-cancelled")" style="font-size:0.7rem;">
                            @(fruit.IsActive ? "Đang bán" : "Ẩn")
                        </span>
                    </td>
                    @if (userRole == "Admin" || userRole == "Staff")
                    {
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@fruit.FruitId" class="btn-action-view" title="Xem" style="border-radius:8px;">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@fruit.FruitId" class="btn-action-edit" title="Sửa" style="border-radius:8px;">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@fruit.FruitId" class="btn-action-delete" title="Xóa" style="border-radius:8px;">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    }
                </tr>
                stt++;
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(Model.CurrentPage - 1)"
                   asp-route-keyword="@ViewBag.Keyword"
                   asp-route-categoryId="@ViewBag.CategoryId"
                   asp-route-origin="@ViewBag.Origin"
                   asp-route-minPrice="@ViewBag.MinPrice"
                   asp-route-maxPrice="@ViewBag.MaxPrice"
                   asp-route-stockStatus="@ViewBag.StockStatus">
                    <i class="fas fa-chevron-left"></i>
                </a>
            </li>
            @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-keyword="@ViewBag.Keyword"
                       asp-route-categoryId="@ViewBag.CategoryId">@i</a>
                </li>
            }
            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(Model.CurrentPage + 1)"
                   asp-route-keyword="@ViewBag.Keyword"
                   asp-route-categoryId="@ViewBag.CategoryId"
                   asp-route-origin="@ViewBag.Origin"
                   asp-route-minPrice="@ViewBag.MinPrice"
                   asp-route-maxPrice="@ViewBag.MaxPrice"
                   asp-route-stockStatus="@ViewBag.StockStatus">
                    <i class="fas fa-chevron-right"></i>
                </a>
            </li>
        </ul>
        <p class="text-center text-muted small">Hiển thị @(Model.Items.Count()) trong @Model.TotalCount sản phẩm</p>
    </nav>
}

@section Scripts {
    <script>
        var kwInput = document.getElementById('keywordInput');
        var suggestBox = document.getElementById('suggestBox');
        var debounceTimer = null;
        kwInput.addEventListener('input', function() {
            clearTimeout(debounceTimer);
            var q = this.value.trim();
            if (q.length < 2) { suggestBox.innerHTML = ''; return; }
            debounceTimer = setTimeout(function() {
                fetch('/Fruit/AutoComplete?keyword=' + encodeURIComponent(q))
                    .then(r => r.json())
                    .then(data => {
                        suggestBox.innerHTML = '';
                        data.forEach(function(name) {
                            var a = document.createElement('a');
                            a.href = '#';
                            a.className = 'list-group-item list-group-item-action py-2 small';
                            a.textContent = name;
                            a.addEventListener('click', function(e) {
                                e.preventDefault();
                                kwInput.value = name;
                                suggestBox.innerHTML = '';
                            });
                            suggestBox.appendChild(a);
                        });
                    });
            }, 250);
        });
        document.addEventListener('click', function(e) {
            if (!suggestBox.contains(e.target) && e.target !== kwInput) suggestBox.innerHTML = '';
        });
    </script>
}
