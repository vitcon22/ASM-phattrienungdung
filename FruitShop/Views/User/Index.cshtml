@using FruitShop.Helpers
@model PagedList<FruitShop.Models.Entities.User>
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "_Layout";
}
@section Breadcrumb {
    <li class="breadcrumb-item active">Người dùng</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="page-title"><i class="fas fa-users me-2 text-success"></i>Quản lý người dùng</h4>
    <div class="d-flex gap-2">
        <a asp-action="ExportCsv" class="btn btn-outline-success btn-sm">
            <i class="fas fa-file-csv me-1"></i>Xuất CSV
        </a>
        <span class="badge bg-primary fs-6 d-flex align-items-center">@Model.TotalCount người</span>
    </div>
</div>

<!-- Thống kê nhanh -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="mini-stat-card text-center">
            <i class="fas fa-user-shield text-danger me-2"></i>
            <span class="text-muted">Admin: </span>
            <strong>@Model.Items.Count(u => u.RoleName == "Admin" || u.RoleName == "Staff")</strong>
            <small class="text-muted"> (trang này)</small>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="mini-stat-card text-center">
            <i class="fas fa-users text-success me-2"></i>
            <span class="text-muted">Khách hàng: </span>
            <strong>@ViewBag.TotalCustomers</strong>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="mini-stat-card text-center">
            <i class="fas fa-user-check text-info me-2"></i>
            <span class="text-muted">Hoạt động: </span>
            <strong>@Model.Items.Count(u => u.IsActive)</strong>
            <small class="text-muted"> (trang này)</small>
        </div>
    </div>
</div>

<!-- Bộ lọc -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Tìm kiếm</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" name="keyword" class="form-control"
                           placeholder="Tên, email, điện thoại..."
                           value="@ViewBag.Keyword" />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label">Vai trò</label>
                <select name="role" class="form-select">
                    <option value="">-- Tất cả --</option>
                    @foreach (var r in new[] { "Admin","Staff","Customer" })
                    {
                        if (ViewBag.Role == r) { <option value="@r" selected>@r</option> }
                        else                   { <option value="@r">@r</option> }
                    }
                </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-success flex-fill"><i class="fas fa-search me-1"></i>Lọc</button>
                <a asp-action="Index" class="btn btn-outline-secondary flex-fill"><i class="fas fa-redo"></i></a>
            </div>
        </form>
    </div>
</div>

<!-- Danh sách -->
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:40px">#</th>
                    <th>Người dùng</th>
                    <th>Email</th>
                    <th>Điện thoại</th>
                    <th class="text-center">Vai trò</th>
                    <th class="text-center">Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="8" class="text-center py-4 text-muted">Không tìm thấy người dùng</td></tr>
                }
                @foreach (var user in Model.Items)
                {
                    var myId = int.Parse(Context.Session.GetString("UserId") ?? "0");
                    <tr class="@(!user.IsActive ? "table-danger" : "")">
                        <td class="text-muted small">@user.UserId</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="user-list-avatar @(user.RoleName == "Admin" ? "admin" : user.RoleName == "Staff" ? "staff" : "")">
                                    <i class="fas fa-user"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold">@user.FullName</div>
                                    @if (!string.IsNullOrEmpty(user.Address))
                                    {
                                        <small class="text-muted text-truncate d-block" style="max-width:180px">@user.Address</small>
                                    }
                                </div>
                            </div>
                        </td>
                        <td class="small">@user.Email</td>
                        <td class="small">@(user.Phone ?? "—")</td>
                        <td class="text-center">
                            <span class="badge @(user.RoleName == "Admin" ? "bg-danger" : user.RoleName == "Staff" ? "bg-info" : "bg-success")">
                                @user.RoleName
                            </span>
                        </td>
                        <td class="text-center">
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Đã khoá</span>
                            }
                        </td>
                        <td class="small text-muted">@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <a asp-action="Details" asp-route-id="@user.UserId"
                                   class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                    <i class="fas fa-eye"></i>
                                </a>
                                @if (user.UserId != myId)
                                {
                                    <form asp-action="ToggleActive" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.UserId" />
                                        <button type="submit"
                                                class="btn btn-sm @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                title="@(user.IsActive ? "Khoá tài khoản" : "Mở khoá")"
                                                onclick="return confirm('@(user.IsActive ? $"Khoá tài khoản {user.FullName}?" : $"Mở khoá tài khoản {user.FullName}?")')">
                                            <i class="fas fa-@(user.IsActive ? "lock" : "lock-open")"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage-1)"
                   asp-route-keyword="@ViewBag.Keyword" asp-route-role="@ViewBag.Role">
                    <i class="fas fa-chevron-left"></i>
                </a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i"
                       asp-route-keyword="@ViewBag.Keyword" asp-route-role="@ViewBag.Role">@i</a>
                </li>
            }
            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage+1)"
                   asp-route-keyword="@ViewBag.Keyword" asp-route-role="@ViewBag.Role">
                    <i class="fas fa-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}
