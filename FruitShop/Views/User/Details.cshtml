@model FruitShop.Models.Entities.User
@{
    ViewData["Title"] = $"Chi tiết người dùng - {Model.FullName}";
    Layout = "_Layout";
    var orders = ViewBag.Orders as List<FruitShop.Models.Entities.Order> ?? new List<FruitShop.Models.Entities.Order>();
}
@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-action="Index">Người dùng</a></li>
    <li class="breadcrumb-item active">@Model.FullName</li>
}

<div class="row g-4">
    <!-- Thông tin tài khoản -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-body text-center">
                <div class="mb-3">
                    <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center"
                         style="width:110px;height:110px">
                        <i class="fas fa-user fa-4x text-success"></i>
                    </div>
                </div>
                <h5 class="mb-1">@Model.FullName</h5>
                <span class="badge bg-@(Model.RoleName == "Admin" ? "danger" : Model.RoleName == "Staff" ? "warning" : "info")">
                    @Model.RoleName
                </span>
                <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">
                    @(Model.IsActive ? "Hoạt động" : "Khoá")
                </span>
                @if (Model.RoleName == "Customer")
                {
                    <div class="mt-3 p-2 bg-light rounded border">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <small class="text-muted">Hạng:</small>
                            <span class="badge bg-warning text-dark">@Model.Tier</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">Điểm:</small>
                            <span class="fw-bold text-success">@Model.Points.ToString("N0")</span>
                        </div>
                    </div>
                }
                <hr />
                <div class="text-start small">
                    <div class="mb-2"><i class="fas fa-envelope text-muted me-2"></i>@Model.Email</div>
                    <div class="mb-2"><i class="fas fa-phone text-muted me-2"></i>@(Model.Phone ?? "—")</div>
                    <div class="mb-2"><i class="fas fa-map-marker-alt text-muted me-2"></i>@(Model.Address ?? "—")</div>
                    <div class="mb-2"><i class="fas fa-calendar text-muted me-2"></i>Tham gia: @Model.CreatedAt.ToString("dd/MM/yyyy")</div>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-3 w-100">
                    <i class="fas fa-arrow-left me-1"></i>Quay lại danh sách
                </a>
            </div>
        </div>
    </div>

    <!-- Thống kê + Lịch sử mua hàng -->
    <div class="col-lg-8">
        @if (Model.RoleName == "Customer")
        {
            <!-- Thống kê tổng quan (RQ14) -->
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card border-success">
                        <div class="card-body text-center">
                            <div class="text-muted small">Tổng đơn hàng</div>
                            <h3 class="text-success mb-0">@ViewBag.TotalOrders</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-primary">
                        <div class="card-body text-center">
                            <div class="text-muted small">Tổng chi tiêu</div>
                            <h3 class="text-primary mb-0">@(((decimal)(ViewBag.TotalSpent ?? 0m)).ToString("N0"))đ</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-warning">
                        <div class="card-body text-center">
                            <div class="text-muted small">Đơn gần nhất</div>
                            <h6 class="text-warning mb-0 mt-2">
                                @(ViewBag.LastOrder != null ? ((DateTime)ViewBag.LastOrder).ToString("dd/MM/yyyy") : "—")
                            </h6>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Lịch sử mua hàng (RQ44) -->
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0"><i class="fas fa-history me-2"></i>Lịch sử mua hàng</h6>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Mã ĐH</th>
                                <th>Ngày đặt</th>
                                <th class="text-end">Tổng tiền</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-center">Chi tiết</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!orders.Any())
                            {
                                <tr><td colspan="5" class="text-center py-4 text-muted">Khách hàng chưa có đơn hàng nào</td></tr>
                            }
                            @foreach (var o in orders.OrderByDescending(x => x.OrderDate))
                            {
                                <tr>
                                    <td><strong>#@o.OrderId</strong></td>
                                    <td class="small text-muted">@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-end fw-bold text-success">@o.TotalAmount.ToString("N0")đ</td>
                                    <td class="text-center">
                                        <span class="badge bg-@o.GetStatusBadge()">@o.GetStatusText()</span>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Order" asp-action="Details" asp-route-id="@o.OrderId"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-body text-muted text-center py-5">
                    <i class="fas fa-info-circle fa-2x mb-2"></i>
                    <div>Người dùng có vai trò @Model.RoleName — không có lịch sử mua hàng</div>
                </div>
            </div>
        }
    </div>
</div>
